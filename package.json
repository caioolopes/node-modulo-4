{
  "name": "modulo-4",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "commit": "cz",
    "dev": "docker compose up -d && npx prisma migrate deploy && tsx watch src/server.ts",
    "prepare": "husky",
    "test:create-prisma-environment": "npm link ./prisma/vitest-environment-prisma",
    "test:install-prisma-environment": "npm link vitest-environment-prisma",
    "build": "tsup src --out-dir build",
    "test": "vitest run --dir src/use-cases",
    "test:watch": "vitest --dir src/use-cases",
    "pretest:e2e": "run-s test:create-prisma-environment test:install-prisma-environment",
    "test:e2e": "vitest --dir src/http",
    "test:e2e:watch": "vitest --dir src/http",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "docker:stop": "docker compose stop"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caioolopes/node-modulo-4.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/caioolopes/node-modulo-4/issues"
  },
  "homepage": "https://github.com/caioolopes/node-modulo-4#readme",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@faker-js/faker": "^10.3.0",
    "@rocketseat/eslint-config": "^1.2.0",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "commitizen": "^4.3.1",
    "eslint": "^8.39.0",
    "eslint-plugin-vitest-globals": "^1.3.1",
    "husky": "^9.1.7",
    "typescript": "^5.1.6",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "dayjs": "^1.11.7"
  }
}
